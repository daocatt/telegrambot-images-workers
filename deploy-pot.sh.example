#!/bin/bash

# Sample Environment Deployment Script
# This script handles migrations, uploads all keys from your custom env file to Cloudflare secrets, and deploys the worker.

# ----------------- CONFIGURATION -----------------
# Replace these with your environment details
DB_NAME="your_d1_database_name"
ENV_NAME="pot"          # The wrangler environment name (e.g. pot, production)
ENV_FILE=".env.pot"      # The local environment file holding your secret keys
# -------------------------------------------------

echo "🚣 Step 1: Applying D1 Migrations to ${DB_NAME}..."
npx wrangler d1 migrations apply "${DB_NAME}" --remote --env "${ENV_NAME}"

echo -e "\n🔑 Step 2: Uploading environment parameters as secrets..."
if [ -f "${ENV_FILE}" ]; then
  while IFS= read -r line || [ -n "$line" ]; do
    # Strip carriage returns if file has Windows endings
    line=$(echo "$line" | tr -d '\r')
    # Skip comments and empty lines
    if [[ ! "$line" =~ ^# ]] && [[ "$line" =~ = ]]; then
      key=$(echo "$line" | cut -d'=' -f1)
      val=$(echo "$line" | cut -d'=' -f2- | sed -e 's/^"//' -e 's/"$//')
      if [ -n "$val" ]; then
        echo "   Uploading $key..."
        echo -n "$val" | npx wrangler secret put "$key" --env "${ENV_NAME}" > /dev/null
      fi
    fi
  done < "${ENV_FILE}"
else
  echo "⚠️ ${ENV_FILE} file not found!"
fi

echo -e "\n🚀 Step 3: Deploying Worker to ${ENV_NAME} environment..."
npx wrangler deploy --env "${ENV_NAME}" --minify

echo -e "\n✅ Done! Don't forget to visit your /setWebhook URL."
