# Telegram Bot Token from BotFather
BOT_TOKEN="your_bot_token_here"

# Your Telegram Application Channel ID (where images are stored)
# Must start with -100 if it's a supergroup or channel
CHANNEL_ID="-100xxxxxxxxxx"

# Access Mode: "single" | "multi"
# single: Only the first configured user or explicitly whitelisted users can use the bot
# multi: Any user can request access, admins must approve (if REQUIRE_APPROVAL=true)
ACCESS_MODE="single"

# Require Approval (for whitelist/family mode)
# true: New users are set to 'pending' state and must be manually approved in the Admin Web UI
# false: New users can immediately start using the service without review
REQUIRE_APPROVAL="false"

# Secure random string sent by Telegram to verify webhook authenticity
WEBHOOK_SECRET="your_webhook_secret_here"

# Secure random path to obfuscate the webhook URL, e.g. /webhook/your_webhook_path_secret
WEBHOOK_PATH_SECRET="your_webhook_path_here"

# Worker Base URL (Required)
# The public URL where images will be served (without trailing slash)
BASE_URL="https://your-project.your-subdomain.workers.dev"

# Advanced Optional Domains
# If you bind multiple custom domains to your worker, you can separate them here:
# ADMIN_URL="https://admin.yourdomain.com"
# WEBHOOK_URL="https://api.yourdomain.com"

# Optional Performance/Security Toggles
# ENABLE_PUBLIC_CHECK: true | false
# If true, the /file/:id route will query D1 to check if the image is marked as public.
# If false (default), it acts as a direct pass-through for maximum performance (0 D1 reads).
ENABLE_PUBLIC_CHECK="false"

# ENABLE_GALLERY: true | false
# If true, enables the Gallery/Collection feature allowing users to group images.
ENABLE_GALLERY="false"
