{
  "name": "telegrambot-images-workers",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "generate-secret": "node scripts/generate-secret.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply telegrambot_images_db --remote",
    "db:migrate:local": "wrangler d1 migrations apply telegrambot_images_db --local",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "grammy": "^1.44.0",
    "hono": "^4.12.28",
    "nanoid": "^5.1.16"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.9.3",
    "wrangler": "^4.4.0"
  },
  "overrides": {
    "esbuild": "^0.25.12"
  }
}
